# Database
# Prisma (Transaction Mode via Supavisor/PgBouncer)
DATABASE_URL="postgresql://user:password@db.project-ref.supabase.co:6543/postgres?pgbouncer=true"
# Direct / Session Mode (Supavisor)
DIRECT_URL="postgresql://user:password@db.project-ref.supabase.co:5432/postgres"

# JWT (RS256 Mandatory)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KEY_VERSION="v1"
JWT_EXPIRATION="15m"
ENCRYPTION_KEY="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f" # 64 hex chars

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Supabase
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Redis / BullMQ
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# WhatsApp API
WHATSAPP_API_TOKEN="your-whatsapp-api-token"

# Telegram API
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# App
PORT=3000
NODE_ENV="development"
