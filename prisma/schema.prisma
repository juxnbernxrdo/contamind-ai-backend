// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  ruc       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     User[]
  auditLogs AuthAuditLog[]
  delegationGrants DelegationGrant[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  MANAGER
  ACCOUNTANT
  VIEWER
  CUSTOM
}

model User {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  
  firstName       String?
  lastName        String?
  
  email           String    @unique
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  
  passwordHash    String
  passwordChangedAt DateTime @default(now())
  passwordHistory String[]  @default([]) // últimos 5 hashes
  
  roles           Role[]
  
  // 2FA - Encrypted Fields
  twoFAEnabled    Boolean   @default(false)
  totpSecret      String?   // Encrypted ciphertext
  totpIv          String?   // Initialization Vector
  totpAuthTag     String?   // Authentication Tag
  backupCodes     String[]  @default([]) // Hashed backup codes
  
  // Sessions
  sessions        AuthSession[]
  devices         AuthDevice[]
  
  // Security
  accountLocked   Boolean   @default(false)
  accountLockedUntil DateTime?
  accountDisabled Boolean   @default(false)
  securityVersion Int       @default(1) // Incremented on critical security events (pwd change, MFA toggle)
  
  // Preferences
  rememberMe      Boolean   @default(false)
  inactivityTimeout Int     @default(28800) // 8 horas
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  permissions     Permission[]
  delegationGrants DelegationGrant[]
  
  @@index([tenantId])
  @@index([email])
}

model Permission {
  id        String   @id @default(uuid())
  module    String
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  deviceId        String
  device          AuthDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  accessToken     String    @unique
  refreshToken    String    @unique
  refreshTokenFamily String? // para detección de replay
  
  securityVersion Int       @default(1) // Captures User.securityVersion at time of issuance
  
  expiresAt       DateTime
  refreshExpiresAt DateTime
  
  revokedAt       DateTime?
  revokeReason    String?
  
  lastActivityAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AuthDevice {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String    // "Mi iPhone", "Laptop trabajo"
  deviceType      String    // "ios", "android", "web", "desktop"
  userAgent       String
  ipAddress       String
  fingerprint     String    // device fingerprint
  
  osVersion       String?
  appVersion      String?
  
  isTrusted       Boolean   @default(false)
  trustedUntil    DateTime?
  
  lastActivityAt  DateTime  @default(now())
  lastActivityIp  String?
  
  sessions        AuthSession[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@index([fingerprint])
}

model AuthAuditLog {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  
  userId          String
  action          String    // login, logout, register, etc.
  
  ipAddress       String
  userAgent       String
  deviceId        String?
  geolocation     Json?     // { country, city, lat, lng }
  
  result          String    // "success", "failure"
  reason          String?
  
  metadata        Json?     // action-specific data
  durationMs      Int?
  severity        String    // "info", "warning", "error", "critical"
  
  previousHash    String?
  hash            String?
  
  createdAt       DateTime  @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([hash])
}

model AuthTokenBlacklist {
  id              String    @id @default(cuid())
  jti             String    @unique // JWT ID
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  
  @@index([expiresAt])
}

model ServicePrincipal {
  id          String    @id @default(cuid())
  name        String    @unique // e.g., "sri-agent", "iess-agent"
  description String?
  hashedSecret String?   // Hashed secret for M2M verification
  publicKey   String?   // For verifying signed requests from agent if needed
  isActive    Boolean   @default(true)
  securityVersion Int   @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  grants      DelegationGrant[]
}

model DelegationGrant {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  
  delegatorUserId String
  delegator       User      @relation(fields: [delegatorUserId], references: [id])
  
  agentId         String
  agent           ServicePrincipal @relation(fields: [agentId], references: [id])
  
  actionScope     String    // e.g., "sri:declaracion_iva:enviar"
  status          String    @default("pending") // pending, approved, consumed, expired, revoked
  
  contextMetadata Json?     // data about the action
  
  actionToken     String?   @unique // The nonce signed after MFA
  expiresAt       DateTime
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([delegatorUserId])
  @@index([agentId])
  @@index([actionToken])
}
